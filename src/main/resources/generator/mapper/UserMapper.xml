        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ecom.mall.modules.user.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="org.ecom.mall.modules.user.domain.User">
